{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kordix",
  "version": "0.1.0",
  "identifier": "com.kordix",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kordix",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGNkE4NDgxQjJDOTIwNUIKUldSYklNbXlnWVJxbjFpKzRKV0hVS3RkMGJtRGRoUHpYU1k2SkxKbGsycDRWZGdkSDFqZTNIbjcK",
      "endpoints": [
        "https://github.com/acedehra/kordix_init/releases/latest/download/latest.json"
      ]
    }
  }
}